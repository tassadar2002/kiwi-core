{
	"name": "kiwi/core",
	"type": "library",
	"description": "",
	"keywords": [
		"kiwi"
	],
	"license": "MIT",
	"authors": [
		{
			"name": "kiwi",
			"email": "kiwi@123.com"
		}
	],
	"require": {
		"php": "^8.0",
		"laravel/framework": "^8.0",
		"jaeger/phpquery-single": "^1.0",
		"guzzlehttp/guzzle": "^7.0",
		"jdavidbakr/replaceable-model": "^1.3",
		"iidestiny/laravel-filesystem-oss": "^2.1",
		"intervention/image": "^2.7"
	},
	"minimum-stability": "beta",
	"require-dev": {
		"encore/laravel-admin": "1.*",
		"dcat/laravel-admin": "2.*",
		"mockery/mockery": "^1.0",
		"phpunit/phpunit": "^9.0",
		"orchestra/testbench": "^6.19"
	},
	"autoload": {
		"psr-4": {
			"Kiwi\\Core\\": "src/"
		},
		"files": [
			"src/Foundation/helpers.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"Kiwi\\Core\\Provider\\KiwiServiceProvider"
			],
			"alias": {
				"AdminRoute": "Kiwi\\Core\\Admin\\Facades\\Admin",
				"Route": "Kiwi\\Core\\Admin\\Facade\\Route"
			}
		}
	},
	"scripts": {
		"post-autoload-dump": [
			"@php ./vendor/bin/testbench package:discover --ansi"
		]
	}
}
